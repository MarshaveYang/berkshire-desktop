{
  "name": "berkshire-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run gen:skills && vite",
    "gen:skills": "node scripts/generate-skills-data.mjs",
    "build": "npm run gen:skills && tsc -b && vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --d1 DB=berkshire-desktop-db --local",
    "db:migrate:local": "wrangler d1 execute berkshire-desktop-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute berkshire-desktop-db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250909.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@tailwindcss/typography": "^0.5.15",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wrangler": "^3.78.0"
  }
}
